# ─── Besu version ────────────────────────────────────────────────────────────
BESU_VERSION=26.6.1

# ─── Network parameters ───────────────────────────────────────────────────────
CHAIN_ID=1337
# blockperiod raised (2->4) and request timeout raised (4->16) so a 50-validator
# QBFT mesh survives: fewer blocks/sec cut the O(n^2) message rate, and the longer
# timeout prevents round-change storms that overflow the BFT event queue.
BLOCK_PERIOD_SECONDS=4
EPOCH_LENGTH=30000
REQUEST_TIMEOUT_SECONDS=16
INITIAL_VALIDATOR_COUNT=4

# ─── Initial validator funding ─────────────────────────────────────────────────
# These are the Besu dev accounts (PUBLICLY KNOWN KEYS – lab use only)
ALLOC_ADDR_1=fe3b557e8fb62b89f4916b721be55ceb828dbd73
ALLOC_ADDR_2=627306090abaB3A6e1400e9345bC60c78a8BEf57
ALLOC_ADDR_3=f17f52151EbEF6C7334FAD080c5704D77216b732

# ─── Fixed container IPs (subnet: 172.16.240.0/24) ───────────────────────────
# Besu requires IP addresses (not hostnames) in enode URLs and --p2p-host.
# These are used in static-nodes.json and assigned via docker-compose ipam.
VALIDATOR_1_IP=172.16.240.11
VALIDATOR_2_IP=172.16.240.12
VALIDATOR_3_IP=172.16.240.13
VALIDATOR_4_IP=172.16.240.14

# ─── Internal container ports (all nodes use the same internal port) ──────────
P2P_PORT=30303
RPC_PORT=8545
METRICS_PORT=9545

# ─── Host-side port ranges ────────────────────────────────────────────────────
# validator-1 → 30303 / 8545 / 9545
# validator-2 → 30304 / 8546 / 9546
# validator-3 → 30305 / 8547 / 9547
# validator-4 → 30306 / 8548 / 9548

# ─── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
